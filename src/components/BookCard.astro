---
interface Book {
  slug: string;
  title: string;
  author: string;
  cover: string;
  theme: string;
  year: string;
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
---

<a 
  href={`/books/${book.slug}`} 
  class="block group"
>
  <div class="aspect-[3/4] bg-gray-900 overflow-hidden mb-4">
    {book.cover ? (
      <img 
        src={book.cover} 
        alt={book.title}
        class="w-full h-full object-cover card-hover"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gray-800">
        <span class="heading-md text-gray-600">{book.title.charAt(0)}</span>
      </div>
    )}
  </div>
  
  <div class="space-y-1">
    <h3 class="text-sm tracking-[0.2em] uppercase font-medium group-hover:opacity-70 transition-opacity">
      {book.title}
    </h3>
    <p class="text-xs tracking-[0.15em] uppercase text-gray-500">
      {book.author}
    </p>
    <p class="text-xs tracking-[0.1em] text-gray-600">
      {book.year}
    </p>
  </div>
</a>

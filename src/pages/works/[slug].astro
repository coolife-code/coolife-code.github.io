---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const works = [
    {
      slug: 'project-one',
      title: 'PROJECT ONE',
      description: 'A web application built with modern technologies',
      year: '2024',
      tags: ['Web', 'React', 'TypeScript', 'Tailwind CSS'],
      content: `
这是一个使用现代技术栈构建的 Web 应用程序。

项目采用了 React 18 和 TypeScript，配合 Tailwind CSS 实现了响应式设计。后端使用 Node.js 和 PostgreSQL。

主要功能包括：
- 用户认证和授权
- 实时数据同步
- 响应式设计
- 性能优化
      `,
      links: [
        { label: 'LIVE DEMO', url: 'https://example.com' },
        { label: 'GITHUB', url: 'https://github.com' },
      ],
    },
    {
      slug: 'project-two',
      title: 'PROJECT TWO',
      description: 'Mobile app for productivity enthusiasts',
      year: '2024',
      tags: ['Mobile', 'Flutter', 'Dart', 'Firebase'],
      content: `
这是一个使用 Flutter 构建的跨平台移动应用。

应用帮助用户管理日常任务和习惯，支持 iOS 和 Android 平台。

主要功能包括：
- 任务管理
- 习惯追踪
- 数据统计
- 云端同步
      `,
      links: [
        { label: 'APP STORE', url: 'https://apple.com' },
        { label: 'PLAY STORE', url: 'https://play.google.com' },
      ],
    },
    {
      slug: 'project-three',
      title: 'PROJECT THREE',
      description: 'Data visualization dashboard',
      year: '2023',
      tags: ['Data', 'D3.js', 'Python', 'Flask'],
      content: `
这是一个数据可视化仪表板项目。

使用 D3.js 创建交互式图表，后端使用 Python Flask 提供 API 接口。

主要功能包括：
- 多种图表类型
- 实时数据更新
- 数据导出
- 自定义主题
      `,
      links: [
        { label: 'LIVE DEMO', url: 'https://example.com' },
        { label: 'GITHUB', url: 'https://github.com' },
      ],
    },
  ];

  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
---

<Layout title={`${work.title} - Your Name`} currentPage="/works">
  <article class="min-h-screen bg-gradient-to-b from-gray-900 to-black">
    <div class="pt-24 pb-16 px-6 md:px-8">
      <div class="max-w-4xl mx-auto">
        <header class="text-center mb-16">
          <h1 class="heading-lg mb-4">{work.title}</h1>
          <p class="text-body text-gray-400 mb-4">
            {work.description}
          </p>
          <p class="text-sm text-gray-500 tracking-[0.1em]">
            {work.year}
          </p>
        </header>

        <div class="aspect-video bg-gray-800 mb-12 overflow-hidden">
          <div class="w-full h-full flex items-center justify-center">
            <span class="heading-md text-gray-600">PROJECT PREVIEW</span>
          </div>
        </div>

        <div class="prose prose-invert prose-lg max-w-none mb-12">
          {work.content.trim().split('\n\n').map((paragraph: string) => (
            <p class="text-body text-gray-300 leading-relaxed mb-6">
              {paragraph.trim()}
            </p>
          ))}
        </div>

        <div class="flex flex-wrap gap-2 justify-center mb-12">
          {work.tags.map((tag: string) => (
            <span class="px-4 py-2 border border-gray-700 text-xs tracking-[0.2em] uppercase text-gray-400">
              {tag}
            </span>
          ))}
        </div>

        <div class="flex flex-wrap gap-4 justify-center mb-12">
          {work.links.map((link: { label: string; url: string }) => (
            <a 
              href={link.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="btn-primary"
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="text-center">
          <a href="/works" class="btn-primary">
            BACK TO WORKS
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
